<%- include('includes/header', {activePage: null}) %>
<style>
    .flow-content {
        display: none;
    }
    .flow-content.active {
        display: block;
    }
</style>
<div id="create">
    <div class="container">
        <div class="contact">
            <%- include('includes/createNav', { activePage }) %>

            <div class="col-md-12" style="margin-top: 15px; margin-bottom: 20px; padding: 0;">
                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <a id="tab-blank" class="nav-link active" href="#" onclick="switchFlow('blank')" style="border-radius: 0">Blank Project</a>
                    </li>
                    <li class="nav-item">
                        <a id="tab-yolo" class="nav-link" href="#" onclick="switchFlow('yolo')" style="border-radius: 0">YOLO Archive</a>
                    </li>
                    <li class="nav-item">
                        <a id="tab-kwcoco" class="nav-link" href="#" onclick="switchFlow('kwcoco')" style="border-radius: 0">KW Coco Archive</a>
                    </li>
                    <li class="nav-item">
                        <a id="tab-ifcb" class="nav-link" href="#" onclick="switchFlow('ifcb')" style="border-radius: 0">IFCB Archive</a>
                    </li>
                    <li class="nav-item">
                        <a id="tab-bootstrap" class="nav-link" href="#" onclick="switchFlow('bootstrap')" style="border-radius: 0">Bootstrap With Model(s)</a>
                    </li>
                </ul>
            </div>

            <form class="add-project-form flow-content active" action="/createP" method='POST' enctype="multipart/form-data" id="blankForm">
                <h3>Add New Project</h3>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="blank_project_name">Project Name</label>
                        <input id="blank_project_name" name="project_name" aria-label="Project name" type="text" class="form-control" placeholder="Project Name" required>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="blank_upload_images">
                            Upload Images or Videos (.zip or .mp4/.avi/.mov) (Optional)
                        </label>
                        <input id="blank_upload_images" name="upload_images" aria-label="Choose file" type="file" class="form-control-file">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-12">
                        <label for="blank_input_classes">Input classes (separated with commas)</label>
                        <input id="blank_input_classes" name="input_classes" aria-label="Input classes. Separated by commas." type="text" class="form-control" placeholder="cat,dog,large mouse" required>
                        <p>Do not add leading or trailing spaces between classes</p>
                    </div>
                </div>
                <div class="col text-center">
                    <hr class="my-4">
                    <input type="submit" aria-label="submit" class="btn btn-primary btn-lg" value="submit" style="border-radius: 0">
                </div>
            </form>

            <form class="add-project-form flow-content" action="/api/projects/import-yolo" method='POST' enctype="multipart/form-data" id="yoloForm">
                <h3>Import YOLO Project</h3>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="yolo_project_name">Project Name</label>
                        <input id="yolo_project_name" name="project_name" aria-label="Project name" type="text" class="form-control" placeholder="Project Name" required>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="yolo_task_type">YOLO Task Type</label>
                        <select id="yolo_task_type" name="task_type" class="form-control">
                            <option value="detect">Object Detection (detect)</option>
                            <option value="classify">Classification (classify)</option>
                            <option value="segment">Instance Segmentation (segment)</option>
                            <option value="pose">Pose Estimation (pose)</option>
                            <option value="obb">Oriented Bounding Box (obb)</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="yolo_archive">Upload YOLO Archive (.zip) <span style="color: red;">*</span></label>
                        <input id="yolo_archive" name="yolo_archive" aria-label="YOLO Archive" type="file" class="form-control-file" required>
                        <p>Should contain images, labels, and YAML/txt class definition</p>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="yolo_weights">Upload Model Weights (.pt / .weights) (Optional)</label>
                        <input id="yolo_weights" name="yolo_weights" aria-label="YOLO Weights" type="file" class="form-control-file">
                    </div>
                </div>
                <div class="col text-center">
                    <hr class="my-4">
                    <input type="submit" aria-label="submit" class="btn btn-primary btn-lg" value="submit" style="border-radius: 0">
                </div>
            </form>

            <form class="add-project-form flow-content" action="/api/projects/import-kwcoco" method='POST' enctype="multipart/form-data" id="kwcocoForm">
                <h3>Import KW Coco Project</h3>
                <div class="form-row">
                    <div class="form-group col-md-12">
                        <label for="coco_project_name">Project Name</label>
                        <input id="coco_project_name" name="project_name" aria-label="Project name" type="text" class="form-control" placeholder="Project Name" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="coco_archive">Upload KW Coco Archive (.zip) <span style="color: red;">*</span></label>
                        <input id="coco_archive" name="coco_archive" aria-label="KW Coco Archive" type="file" class="form-control-file" required>
                        <p>Should contain images and input_coco.json annotations</p>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="viame_model">Upload VIAME Model File (Optional)</label>
                        <input id="viame_model" name="viame_model" aria-label="VIAME Model" type="file" class="form-control-file">
                    </div>
                </div>
                <div class="col text-center">
                    <hr class="my-4">
                    <input type="submit" aria-label="submit" class="btn btn-primary btn-lg" value="submit" style="border-radius: 0">
                </div>
            </form>

            <form class="add-project-form flow-content" action="/api/projects/import-ifcb" method='POST' enctype="multipart/form-data" id="ifcbForm">
                <h3>Import IFCB Project</h3>
                <div class="form-row">
                    <div class="form-group col-md-12">
                        <label for="ifcb_project_name">Project Name</label>
                        <input id="ifcb_project_name" name="project_name" aria-label="Project name" type="text" class="form-control" placeholder="Project Name" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-12">
                        <label for="ifcb_archive">Upload IFCB Archive (.zip) <span style="color: red;">*</span></label>
                        <input id="ifcb_archive" name="ifcb_archive" aria-label="IFCB Archive" type="file" class="form-control-file" required>
                        <p>Should contain .roi and .adc files (and optionally .hdr files)</p>
                    </div>
                </div>
                <div class="col text-center">
                    <hr class="my-4">
                    <input type="submit" aria-label="submit" class="btn btn-primary btn-lg" value="submit" style="border-radius: 0">
                </div>
            </form>

            <form class="add-project-form flow-content" action="/createP" method='POST' enctype="multipart/form-data" id="bootstrapForm">
                <h3>Add New Project</h3>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="bootstrap_project_name">Project Name</label>
                        <input id="bootstrap_project_name" name="project_name" aria-label="Project name" type="text" class="form-control" placeholder="Project Name" required>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="bootstrap_upload_images">
                            Upload Images or Videos (.zip or .mp4/.avi/.mov) (Optional)
                        </label>
                        <input id="bootstrap_upload_images" name="upload_images" aria-label="Choose file" type="file" class="form-control-file">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-12">
                        <label for="bootstrap_input_classes">Input classes (separated with commas)</label>
                        <input id="bootstrap_input_classes" name="input_classes" aria-label="Input classes. Separated by commas." type="text" class="form-control" placeholder="cat,dog,large mouse" required>
                        <p>Do not add leading or trailing spaces between classes</p>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="bootstrap_model_format">Model Format</label>
                        <select id="bootstrap_model_format" name="model_format" class="form-control">
                            <option value="darknet">Darknet (.data + .cfg + .weights)</option>
                            <option value="ultralytics">Ultralytics YOLO (PyTorch .pt)</option>
                        </select>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="upload_bootstrap">Upload Model Zips (multiple allowed)</label>
                        <input id="upload_bootstrap" aria-label="Upload Model Zips" name="upload_bootstrap" type="file" class="form-control-file" multiple required>
                    </div>
                </div>
                <div class="col text-center">
                    <hr class="my-4">
                    <input type="submit" aria-label="submit" class="btn btn-primary btn-lg" value="submit" style="border-radius: 0">
                </div>
            </form>

            <div class="col text-center" style="margin-top: 15px;">
                <label for="progress" id="progress" aria-live="polite" aria-atomic="true" style="font-weight: bold; color: #1569AE;"></label>
            </div>
        </div>
    </div>
</div>

<script>
    const PNames = "<%= PNames %>".split(",");

    function switchFlow(flow) {
        document.getElementById('tab-blank').classList.remove('active');
        document.getElementById('tab-yolo').classList.remove('active');
        document.getElementById('tab-kwcoco').classList.remove('active');
        document.getElementById('tab-ifcb').classList.remove('active');
        document.getElementById('tab-bootstrap').classList.remove('active');

        document.getElementById('tab-' + flow).classList.add('active');

        document.querySelectorAll('.flow-content').forEach(form => {
            form.classList.remove('active');
        });
        document.getElementById(flow + 'Form').classList.add('active');
    }

    function validateProjectName(name) {
        if (!name) return false;

        const invalidChars = ['/', '@', '\\', '.', "'", ' '];
        for (let char of invalidChars) {
            if (name.includes(char)) {
                alert("Invalid Project Name!\nProject name cannot contain spaces or characters like: / @ \\ . '");
                return false;
            }
        }

        if (PNames.includes(name)) {
            alert("A project with that name already exists!");
            return false;
        }

        return true;
    }

    document.querySelectorAll('.flow-content').forEach(form => {
        form.addEventListener('submit', function(event) {
            event.preventDefault();

            const formId = this.id;
            let nameFieldId = 'blank_project_name';
            if (formId === 'yoloForm') nameFieldId = 'yolo_project_name';
            if (formId === 'kwcocoForm') nameFieldId = 'coco_project_name';
            if (formId === 'bootstrapForm') nameFieldId = 'bootstrap_project_name';
            if (formId === 'ifcbForm') nameFieldId = 'ifcb_project_name';

            const projectName = document.getElementById(nameFieldId).value;
            if (!validateProjectName(projectName)) {
                return;
            }

            const formData = new FormData(this);
            const xhr = new XMLHttpRequest();
            const progress = document.getElementById('progress');

            progress.textContent = "Percent Uploaded: 0%";
            document.querySelectorAll('input[type="submit"]').forEach(btn => btn.style.display = "none");

            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) {
                    const percent = Math.round((e.loaded / e.total) * 100);
                    progress.textContent = `Percent Uploaded: ${percent}%`;
                    if (percent === 100) {
                        progress.textContent = "Upload Finished. Server processing upload. Please wait for the closing prompt.";
                    }
                }
            });

            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    document.querySelectorAll('input[type="submit"]').forEach(btn => btn.style.display = "inline-block");

                    if (xhr.status === 200) {
                        alert("Project creation successful");
                        window.location.replace('/home');
                    } else {
                        progress.textContent = "";
                        let errMsg = 'Something went wrong during project creation.';
                        try {
                            const resObj = JSON.parse(xhr.responseText);
                            if (resObj && resObj.message) errMsg += `\nReason: ${resObj.message}`;
                        } catch(e) {
                            if (xhr.responseText) errMsg += `\nDetails: ${xhr.responseText}`;
                        }
                        alert(errMsg);
                    }
                }
            };

            xhr.open('POST', this.action, true);

            if (formId === 'blankForm') {
                const uploadImages = document.getElementById('blank_upload_images');

                if (uploadImages.files.length > 0) {
                    const file = uploadImages.files[0];

                    if (file.name.endsWith('.mp4') || file.name.endsWith('.mov') || file.name.endsWith('.avi')) {
                        const frameRate = prompt("Please enter a number for the framerate the video should be split by. (ex: 30)");

                        if (frameRate) {
                            formData.delete('upload_images');
                            formData.append('upload_video', file);
                            formData.append('frame_rate', frameRate);
                        } else {
                            progress.textContent = "";
                            document.querySelectorAll('input[type="submit"]').forEach(btn => btn.style.display = "inline-block");
                            return;
                        }
                    }
                }
            }

            if (formId === 'bootstrapForm') {
                const uploadImages = document.getElementById('bootstrap_upload_images');

                if (uploadImages.files.length > 0) {
                    const file = uploadImages.files[0];

                    if (file.name.endsWith('.mp4') || file.name.endsWith('.mov') || file.name.endsWith('.avi')) {
                        const frameRate = prompt("Please enter a number for the framerate the video should be split by. (ex: 30)");

                        if (frameRate) {
                            formData.delete('upload_images');
                            formData.append('upload_video', file);
                            formData.append('frame_rate', frameRate);
                        } else {
                            progress.textContent = "";
                            document.querySelectorAll('input[type="submit"]').forEach(btn => btn.style.display = "inline-block");
                            return;
                        }
                    }
                }
            }

            xhr.send(formData);
        });
    });
</script>
<%- include('includes/footer') %>
